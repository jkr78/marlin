# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# cargo-fuzz runtime artifacts (don't commit crashes or the in-progress
# corpus — release fuzzing will curate a small regression corpus later,
# per PRD §F3)
fuzz/artifacts/
fuzz/corpus/
fuzz/Cargo.lock

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Ignore all files starting with a dot
.*

# But allow these specific ones
!.gitignore
!.github/
!.vscode/
!.python-version
!.env.example
!.env.template


# --- AI & Agentic Rules ---
# Universal
AGENTS.md
AI.md

# Anthropic Claude
CLAUDE.md
CLAUDE.local.md
.claude/

# Google Gemini
GEMINI.md
.gemini/

# Cursor & Windsurf
.cursorrules
.cursor/rules/
.windsurfrules
.windsurf/rules/

# General/Temporary
*.agent.md
MEMORY.md
.aichat/

# Local MCP server configurations (contains sensitive keys/local paths)
.mcp.json

# Ignore all files starting with .env
.env*

# Except for the example/template file (optional but recommended)
!.env.example
!.env.template

# Specifically targeting your dynamic app files
.env.local.*

